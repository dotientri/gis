pipeline {
  agent any
  environment {
    DOCKERHUB = "${DOCKERHUB_USERNAME}"
    REPO_PREFIX = "${REPO_PREFIX}"
    NAMESPACE = "myapp"
    KUBECONFIG_CRED = 'kubeconfig'
    DOCKERHUB_CRED = 'dockerhub-creds'
  }
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }
    stage('Prepare tag') {
      steps {
        script {
          env.IMG_TAG = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
          echo "Build tag: ${env.IMG_TAG}"
        }
      }
    }
    stage('Build & Push Docker Images') {
      steps {
        withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CRED}", usernameVariable: 'DH_USER', passwordVariable: 'DH_PASS')]) {
          dir('qlycv') {
            sh '''
              echo $DH_PASS | docker login -u $DH_USER --password-stdin
              docker build -f backend/Dockerfile -t ${DH_USER}/${REPO_PREFIX}-backend:${IMG_TAG} .
              docker push ${DH_USER}/${REPO_PREFIX}-backend:${IMG_TAG}
              docker build -f frontend/Dockerfile -t ${DH_USER}/${REPO_PREFIX}-frontend:${IMG_TAG} .
              docker push ${DH_USER}/${REPO_PREFIX}-frontend:${IMG_TAG}
            '''
          }
        }
      }
    }
    stage('Deploy to k3s') {
      steps {
        withCredentials([file(credentialsId: "${KUBECONFIG_CRED}", variable: 'KUBECONFIG_FILE'), usernamePassword(credentialsId: "${DOCKERHUB_CRED}", usernameVariable: 'DH_USER', passwordVariable: 'DH_PASS')]) {
          dir('qlycv') {
            sh '''
              export KUBECONFIG=$KUBECONFIG_FILE
              kubectl apply -f k8s/namespace.yaml
              kubectl apply -f k8s/postgres.yaml
              sed "s|DOCKERHUB_USERNAME|${DH_USER}|g; s|TAG|${IMG_TAG}|g" k8s/backend-deployment.yaml | kubectl -n ${NAMESPACE} apply -f -
              sed "s|DOCKERHUB_USERNAME|${DH_USER}|g; s|TAG|${IMG_TAG}|g" k8s/frontend-deployment.yaml | kubectl -n ${NAMESPACE} apply -f -
              kubectl apply -f k8s/service.yaml -n ${NAMESPACE}
            '''
          }
        }
      }
    }
  }
  post {
    success {
      echo "Pipeline succeeded: ${env.BUILD_TAG}"
    }
    failure {
      echo "Pipeline failed"
    }
  }
}
