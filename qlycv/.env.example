# Django Settings
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production
BACKEND_IMAGE=hiiamgay/qlycv-backend:latest
FRONTEND_IMAGE=hiiamgay/qlycv-frontend:latest

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=gis_database
DB_USER=admin
DB_PASSWORD=YourPassword123
DB_HOST=db
DB_PORT=5432

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,gis.example.com

# CORS Settings
FRONTEND_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# Email Configuration
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your-mailtrap-user
EMAIL_HOST_PASSWORD=your-mailtrap-password
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=noreply@qlycv.local
CONTACT_RECEIVER_EMAIL=admin@example.com

# Optional: Gunicorn settings
WORKERS=4
WORKER_CLASS=sync
TIMEOUT=120
